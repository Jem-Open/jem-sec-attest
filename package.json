{
  "name": "jem-sec-attest",
  "version": "0.1.0",
  "description": "Multi-tenant security attestation training platform",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Jem-Open contributors",
  "repository": { "type": "git", "url": "https://github.com/Jem-Open/jem-sec-attest.git" },
  "bugs": { "url": "https://github.com/Jem-Open/jem-sec-attest/issues" },
  "homepage": "https://github.com/Jem-Open/jem-sec-attest#readme",
  "keywords": ["security", "compliance", "multi-tenant", "ai", "training"],
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "generate:schema": "tsx scripts/generate-schema.ts",
    "docker:up": "docker compose -f docker/compose.yml up --build -d --wait",
    "docker:down": "docker compose -f docker/compose.yml down -v",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/azure": "^3.0.38",
    "@ai-sdk/openai": "^3.0.37",
    "ai": "^6.0.105",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "iron-session": "^8.0.4",
    "next": "^16.1.6",
    "openid-client": "^6.8.2",
    "pdfkit": "^0.17.2",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "safe-stable-stringify": "^2.5.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.58.2",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.1",
    "lefthook": "^2.1.4",
    "testcontainers": "^11.13.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "minimatch@<10.2.3": ">=10.2.3",
      "rollup@<4.59.0": ">=4.59.0"
    }
  }
}
